FRAMEIO_SIGNING_SECRET=
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=
# generated after oauth/callback URL
ADOBE_REFRESH_TOKEN=
# fetched from accounts
FRAMEIO_ACCOUNT_ID=
# set to trigger oauth endpoint flow
OAUTH_CALLBACK_ENABLED=false

# --- Google Sheets integration (active) ---
# Spreadsheet ID from its URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
SHEET_ID=
# Service account JSON (entire file contents, single line). The service account
# must be shared (Editor) on the spreadsheet. Each tab is named after a Frame.io
# project and has a header row with columns: File ID, Name, SME, PM, Status,
# Notes, MODULE, ID (matched case-insensitively).
GOOGLE_SERVICE_ACCOUNT_JSON=
SHEETS_ENABLED=true

# --- Airtable integration (retained but disabled by default) ---
# Set AIRTABLE_ENABLED=true to re-activate writes to Airtable.
AIRTABLE_ENABLED=false
AIRTABLE_PAT=
AIRTABLE_BASE_ID=
